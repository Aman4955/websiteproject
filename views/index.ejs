<body>
    <div class="container">
    <div class="header">
        

            <h1 class="websitelogo">
                <!-- <img src="/style/images/weblogo.png" alt="">  </h1> -->
            <h1>Bellary Bazar</h1>

    

    </div>


    <!-- =============top side item and icon===================== -->


    <div class="menu">
        <div class="threelines">
           

        </div>
        <div class="search">

    <img src="/style/images/magnifying-glass-solid.png" class="search-icon" alt="search">

    <input type="search" id="sh" placeholder="Search">

