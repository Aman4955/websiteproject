            </div>
            <div class="cart">
                <a href="/cart">
                <img src="/style/images/cart-arrow-down-solid.png" alt="">
                    </a>
            </div>

        </div>

    </div>

<!-- ================icons company============== -->
<div class="navigation">
    <div class="links">
        <a href="" class="nav-links">| Mobiles     |</a>
    </div>
 
     <div class="links">
        <a href="" class="nav-links">| Laptop  |</a>
