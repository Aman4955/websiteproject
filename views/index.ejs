    <!-- ===============freame itams=============== -->



 <div class="content">

  <% products.forEach(p => { %>

    <div class="frame">

      <!-- IMAGE -->
      <div class="p1">
        <img src="<%= p.image %>" alt="">
        
      </div>

      <!-- NAME -->
      <div class="p2">
        <p><%= p.name %></p>
      </div>

      <!-- BUTTON -->
      <form action="/cart" method="POST">
        <input type="hidden" name="name" value="<%= p.name %>">
        <input type="hidden" name="image" value="<%= p.image %>">

        <button type="submit">Add</button>
      </form>

    </div>

  <% }) %>

</div>

 <%- include("partials/footer") %>
    </div>
    <!-- <script src='indexjs.js'></script> -->
    
</body>
</html>
