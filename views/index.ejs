<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Bellary Bazar</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <link rel='stylesheet' type='text/css' media='screen' href='/style/indexcs.css'>
</head>

<body>
<div class="container">

    <div class="header">
        <h1>Bellary Bazar</h1>
    </div>

    <!-- ================= MENU ================= -->
    <div class="menu">
        <p><a href="/"><img src="/images/house.jpg" alt="" width="50" height="50"></a></p>
        <div class="search">

        <!-- 🔥 SEARCH (FIXED) -->
        <form action="/search" method="GET" class="search">

            

            <input type="search" name="q" id="sh" placeholder="Search mobiles..." required >
            <button type="submit" id="sa"><img src="/images/serch.png" class="search-icon" ></button></input>
            
       
            

        </form>
</div>
        <div class="more-option">
            <div class="like-item">
                <img src="/images/like1.jpg" alt="">
            </div>

            <div class="reg">
                <a href="/sign">
                    <img src="/images/login.png" alt="">
                </a>
            </div>

            <div class="cart">
                <a href="/cart">
                    <img src="/images/cart.png" alt="">
                </a>
            </div>
        </div>

    </div>

    <!-- ================= NAVIGATION ================= -->
    <div class="navigation">
        <div class="links">
            <a href="/mobile" class="nav-links">| Mobiles |</a>
        </div>

        <div class="links">
            <a href="/laptop" class="nav-links">| Laptop |</a>
        </div>

        <div class="links">
            <a href="" class="nav-links">| Burds |</a>
        </div>

        <div class="links">
            <a href="" class="nav-links">| Electronic |</a>
        </div>
    </div>

    <!-- ================= WARNING ================= -->
    <div class="worning">
        <marquee>
            <p><samp>⚠️ Warning</samp>: Please login or signup to continue.</p>
        </marquee>
    </div>

    <!-- ================= ADS ================= -->
    <div class="ads">

        <div class="ad big">
            <img src="<%= ads[0].image %>" alt="">
        </div>

        <div class="center-ads">
            <% for(let i = 1; i <= 4; i++) { %>
                <div class="ad small">
                    <img src="<%= ads[i].image %>" alt="">
                </div>
            <% } %>
        </div>

        <div class="ad big">
            <img src="<%= ads[5].image %>" alt="">
        </div>

    </div>

    <!-- ================= PRODUCTS ================= -->
    <div class="content" >
        

            <% if(products.length>0){%>
        <% products.forEach(p => { %>

            

        <a href="<%= p.link %>">
        <div class="frame" >

            <div class="p1">
                <img src="<%= p.image %>" alt="">
            </div>

            <div class="p2">
                <p><%= p.name %></p>
            </div>

            <form action="/cart" method="POST">
                <input type="hidden" name="name" value="<%= p.name %>">
                <input type="hidden" name="image" value="<%= p.image %>">

               <button onclick="addToCart('<%= p.name %>', '<%= p.image %>', '<%= p.price || 10000 %>')" class="btu">
  Add 
</button>
  </form>
<!-- =======
                <button type="submit" >Add</button>           -->

        </div>
       
        </a>


        

        <% }) %>
        <%} else{%>
        <div style="text-align: center;margin: 50px;">
            <h2>item not found</h2>
            <p>Try searching something else</p>
        </div>
        <%}%>
        

    </div>

    <%- include("partials/footer") %>

</div>
</body>
</html>