    </div>
     <div class="links">
        <a href="" class="nav-links">| Electronic |</a>
    </div>
</div>
<!-- ==============worning===================== -->
 <div class="worning">
    <p><samp>⚠️ Warning</samp>: Please login or signup to continue.</p>
 </div>
    <!-- ==================== ads class code================ -->
<div class="ads">

  <!-- Left Big Ad -->
  <div class="ad big">
    <img src="<%= ads[0].image %>" alt="">
  </div>

  <!-- Center 4 Small Ads -->
  <div class="center-ads">
    <% for(let i = 1; i <= 4; i++) { %>
      <div class="ad small">
        <img src="<%= ads[i].image %>" alt="">
      </div>
    <% } %>
  </div>

  <!-- Right Big Ad -->
  <div class="ad big">
    <img src="<%= ads[5].image %>" alt="">
  </div>

</div>

