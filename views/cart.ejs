<%- include("partials/header") %>

<h2>My Cart 🛒</h2>

<div class="content">

  <% if(cart.length === 0){ %>
    <p>Cart is empty</p>
  <% } %>

  <% cart.forEach(item => { %>

    <div class="frame">
      <img src="<%= item.image %>" alt="">
      <p><%= item.name %></p>
    </div>

  <% }) %>

</div>

<%- include("partials/footer") %>